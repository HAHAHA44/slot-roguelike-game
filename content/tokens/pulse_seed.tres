[gd_resource type="Resource" script_class="TokenDefinition" load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/content/token_definition.gd" id="1"]

[resource]
script = ExtResource("1")
# 脉冲种子：引擎型 token，吸收周围的 Grow/Charge 标签积累充能，结算时释放为加分
id = "pulse_seed"
name = "Pulse Seed"
description = "Absorbs nearby Grow and Charge energy, building up power over time. Releases accumulated charge as bonus score at the end of each settlement."
rarity = "Common"
type = "Engine"
# 同时携带 Grow 和 Charge 标签，可被自身及其他引擎触发
tags = PackedStringArray("Grow", "Charge")
base_value = 1
# 当棋盘上存在 Grow 或 Charge 标签的 token 时触发充能
trigger_rules = {
"charge_from_tags": PackedStringArray("Grow", "Charge")
}
# charge：当前积累量；max_charge：满充阈值
state_fields = {
"charge": 0,
"max_charge": 2
}
spawn_rules = {
"weight": 1.0
}
remove_rules = {}

