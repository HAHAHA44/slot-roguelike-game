[gd_scene format=3]

[node name="EventDraftPanel" type="PanelContainer"]
visible = false
size_flags_horizontal = 4
size_flags_vertical = 0

[node name="MarginContainer" type="MarginContainer" parent="."]
theme_override_constants/margin_left = 12
theme_override_constants/margin_top = 12
theme_override_constants/margin_right = 12
theme_override_constants/margin_bottom = 12

[node name="VBox" type="VBoxContainer" parent="MarginContainer"]
theme_override_constants/separation = 8

[node name="TitleLabel" type="Label" parent="MarginContainer/VBox"]
text = "Event Draft"

[node name="SummaryLabel" type="Label" parent="MarginContainer/VBox"]
text = "Choose an event."
autowrap_mode = 3

[node name="EventButton1" type="Button" parent="MarginContainer/VBox"]
text = "Event 1"

[node name="EventButton2" type="Button" parent="MarginContainer/VBox"]
text = "Event 2"

[node name="EventButton3" type="Button" parent="MarginContainer/VBox"]
text = "Event 3"
